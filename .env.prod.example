# EC2上でこの内容を元に .env を作成する（.envはコミットしない）
# <rds_endpoint>は `terraform output rds_endpoint` の値（host:port形式）に置き換える
DATABASE_URL=mysql+pymysql://<db_username>:<db_password>@<rds_endpoint>/planner?charset=utf8mb4
# openssl rand -hex 32 等で生成した強力な値に変更すること（デフォルト値のままだとENVIRONMENT=production時に起動失敗する）
JWT_SECRET=change-me-to-a-strong-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ENVIRONMENT=production
# デプロイ先のオリジン（EC2のパブリックIP）に置き換える
CORS_ORIGINS=http://<public_ip>
