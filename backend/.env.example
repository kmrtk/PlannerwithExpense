DATABASE_URL=mysql+pymysql://app:app@mysql:3306/planner?charset=utf8mb4
# 本番相当のデプロイでは強力な値に変更し ENVIRONMENT=production を設定すること
JWT_SECRET=devsecret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ENVIRONMENT=development
# 複数許可する場合はカンマ区切り。本番デプロイ時はデプロイ先のオリジン（例: http://<EC2パブリックIP>）に変更すること
CORS_ORIGINS=http://localhost:5173
